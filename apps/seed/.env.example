# Docker Compose replica set (default in seed-demo.ts).
# From the host, map mongo1–mongo3 to 127.0.0.1 in /etc/hosts, or run: npm run seed:docker
MONGO_URL=mongodb://mongo1:27117,mongo2:27118,mongo3:27119/?replicaSet=car
MONGO_DB_NAME=car

# Host fallback when replica-set member hostnames are not resolvable:
# MONGO_URL=mongodb://127.0.0.1:27117,127.0.0.1:27118,127.0.0.1:27119/?replicaSet=car
